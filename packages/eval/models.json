{
	"$schema": "./models.schema.json",
	"models": {
		"gpt-4o-mini": {
			"id": "gpt-4o-mini",
			"name": "GPT-4o Mini",
			"api": "openai-completions",
			"provider": "openai",
			"baseUrl": "${OPENAI_BASE_URL}",
			"input": ["text", "image"],
			"cost": {
				"input": 0.15,
				"output": 0.6
			},
			"contextWindow": 128000,
			"maxTokens": 16384,
			"headers": {
				"Authorization": "Bearer ${OPENAI_API_KEY}"
			}
		},
		"gpt-4o": {
			"id": "gpt-4o",
			"name": "GPT-4o",
			"api": "openai-completions",
			"provider": "openai",
			"baseUrl": "${OPENAI_BASE_URL}",
			"input": ["text", "image"],
			"cost": {
				"input": 2.5,
				"output": 10
			},
			"contextWindow": 128000,
			"maxTokens": 16384,
			"headers": {
				"Authorization": "Bearer ${OPENAI_API_KEY}"
			}
		},
		"claude-3-5-sonnet": {
			"id": "claude-3-5-sonnet",
			"name": "Claude 3.5 Sonnet",
			"api": "anthropic-messages",
			"provider": "anthropic",
			"baseUrl": "${ANTHROPIC_BASE_URL}",
			"input": ["text", "image"],
			"cost": {
				"input": 3,
				"output": 15
			},
			"contextWindow": 200000,
			"maxTokens": 8192,
			"headers": {
				"x-api-key": "${ANTHROPIC_API_KEY}"
			}
		}
	}
}
