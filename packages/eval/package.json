{
  "name": "@talesofai/agent-eval",
  "version": "0.1.0",
  "private": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/talesofai/talesofai-eval.git",
    "directory": "packages/eval"
  },
  "type": "module",
  "bin": {
    "agent-eval": "./bin/agent-eval.js"
  },
  "files": [
    "bin",
    "src",
    "models.json",
    "models.schema.json",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "agent-eval": "tsx src/cli/index.ts",
    "test": "node --test src/tests/*.test.ts",
    "test:coverage": "c8 --check-coverage --lines 80 --branches 75 --functions 85 --statements 80 --reporter=text-summary --reporter=lcov node --test src/tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm dlx @biomejs/biome check src",
    "generate-schema": "tsx scripts/generate-schema.ts"
  },
  "dependencies": {
    "@mariozechner/pi-ai": "^0.55.4",
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@openai/agents": "^0.4.4",
    "axios": "^1.13.2",
    "cac": "^6.7.14",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "html-minifier-terser": "^7.2.0",
    "openai": "^6.17.0",
    "picocolors": "^1.1.1",
    "pino": "^9.5.0",
    "tsx": "^4.19.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zod3": "npm:zod@^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/html-minifier-terser": "^7.0.2",
    "c8": "^11.0.0",
    "zod-to-json-schema": "^3.25.1"
  }
}
