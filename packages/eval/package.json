{
  "name": "agent-eval",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "bin": {
    "agent-eval": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node scripts/copy-report-templates.mjs",
    "dev": "tsc -p tsconfig.build.json --watch",
    "prepublishOnly": "pnpm build",
    "agent-eval": "node dist/cli.js",
    "test": "node --test src/tests/*.test.ts",
    "typecheck": "tsc --noEmit",
    "lint": "pnpm dlx @biomejs/biome check src/cli.ts src/cli/resolve-cases.ts src/cli/command-utils.ts src/cli/run-command.ts src/cli/diff-command.ts src/cli/matrix-command.ts src/runners/normalize-agent-input.ts src/tests/normalize-agent-input.test.ts src/tests/manuscript-model.test.ts",
    "generate-schema": "node scripts/generate-schema.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.25.3",
    "@openai/agents": "^0.4.4",
    "axios": "^1.13.2",
    "cac": "^6.7.14",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "html-minifier-terser": "^7.2.0",
    "openai": "^6.17.0",
    "picocolors": "^1.1.1",
    "pino": "^9.5.0",
    "yaml": "^2.8.2",
    "zod": "^4.3.6",
    "zod3": "npm:zod@^3.25.76"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/html-minifier-terser": "^7.0.2",
    "zod-to-json-schema": "^3.25.1"
  }
}
