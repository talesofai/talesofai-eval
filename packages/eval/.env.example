# Required: Model for running cases
# Example: https://api.openai.com/v1 or https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Required for llm_judge/diff commands (no default value)
# Example: gpt-4o-mini, qwen-plus, etc.
EVAL_JUDGE_MODEL=

# Optional: Judge model endpoint (defaults to OPENAI_BASE_URL)
EVAL_JUDGE_BASE_URL=

# Optional: Judge API key (defaults to OPENAI_API_KEY)
EVAL_JUDGE_API_KEY=

# Agent runtime: upstream API auth (for type: agent cases)
# Get token at: https://www.neta.art/open/
EVAL_UPSTREAM_X_TOKEN=
EVAL_UPSTREAM_API_BASE_URL=https://api.talesofai.cn

# MCP server configuration (optional, has defaults)
EVAL_MCP_SERVER_BASE_URL=https://mcp.talesofai.cn
EVAL_MCP_X_TOKEN=

# Optional: override legacy agent prompt template file path
EVAL_LEGACY_AGENT_PROMPT_FILE=

# Optional: forwarded token for requests
OPENAI_X_TOKEN=
