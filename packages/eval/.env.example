# required: LLM endpoint for running cases
OPENAI_BASE_URL=
OPENAI_API_KEY=

# required for llm_judge / diff: model registry and judge model id
# create a models.json in your project root (see README for format)
# or point to an existing file:
EVAL_MODELS_PATH=./models.json
EVAL_JUDGE_MODEL=

# optional: multi-model judge (comma-separated model ids from registry)
# EVAL_JUDGE_MODELS=model-a,model-b,model-c
EVAL_JUDGE_AGGREGATION=median

# optional: separate endpoint for judge (e.g. LiteLLM gateway)
# falls back to OPENAI_BASE_URL / OPENAI_API_KEY when unset
# EVAL_JUDGE_BASE_URL=
# EVAL_JUDGE_API_KEY=

# agent runtime — MCP tool server
EVAL_MCP_SERVER_BASE_URL=https://mcp.talesofai.cn
EVAL_MCP_X_TOKEN=

# agent runtime — upstream API (character / asset provider)
EVAL_UPSTREAM_API_BASE_URL=https://api.talesofai.cn
EVAL_UPSTREAM_X_TOKEN=

# optional overrides
# EVAL_LEGACY_AGENT_PROMPT_FILE=
# OPENAI_X_TOKEN=
