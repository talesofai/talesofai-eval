# Required: Model for running cases
OPENAI_BASE_URL=
OPENAI_API_KEY=

# Required for llm_judge/diff commands
# Single model mode (backward compatible):
# EVAL_JUDGE_MODEL=gpt-4o-mini
#
# Multi-model mode via litellm/unified endpoint:
# EVAL_JUDGE_MODELS=gemini-3-flash-preview,qwen3.5-plus,doubao-2.0-mini
EVAL_JUDGE_MODEL=

# Optional: Multi-model judge (comma-separated, uses same endpoint)
# All models call the same EVAL_JUDGE_BASE_URL with EVAL_JUDGE_API_KEY
EVAL_JUDGE_MODELS=

# Optional: Aggregation method (default: median)
# Options: median, mean, iqm
EVAL_JUDGE_AGGREGATION=median

# Optional: Judge endpoint (defaults to OPENAI_BASE_URL)
# For litellm: https://your-litellm-endpoint.com/v1
EVAL_JUDGE_BASE_URL=

# Optional: Judge API key (defaults to OPENAI_API_KEY)
EVAL_JUDGE_API_KEY=

# Agent runtime
EVAL_UPSTREAM_X_TOKEN=
EVAL_UPSTREAM_API_BASE_URL=https://api.talesofai.cn

# MCP server
EVAL_MCP_SERVER_BASE_URL=https://mcp.talesofai.cn
EVAL_MCP_X_TOKEN=

# Optional
EVAL_LEGACY_AGENT_PROMPT_FILE=
OPENAI_X_TOKEN=
