{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "declaration": true,
    "declarationMap": true,
    "moduleResolution": "NodeNext",
    "module": "NodeNext",
    "allowImportingTsExtensions": false,
    "rewriteRelativeImportExtensions": true
  },
  "exclude": ["src/tests/**"]
}
