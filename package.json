{
  "name": "agent-eval-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm --dir packages/eval run typecheck",
    "cli": "pnpm --dir packages/eval run agent-eval",
    "dev": "pnpm --dir packages/eval run agent-eval",
    "test": "pnpm --dir packages/eval run test",
    "test:coverage": "pnpm --dir packages/eval run test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "agent-eval": "pnpm --dir packages/eval run agent-eval"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
