{
  "name": "agent-eval-monorepo",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "pnpm -F @talesofai/agent-eval run typecheck",
    "cli": "tsx packages/eval/src/cli/index.ts",
    "dev": "tsx packages/eval/src/cli/index.ts",
    "test": "pnpm -F @talesofai/agent-eval run test",
    "test:coverage": "pnpm -F @talesofai/agent-eval run test:coverage",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "agent-eval": "tsx packages/eval/src/cli/index.ts"
  },
  "devDependencies": {
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
